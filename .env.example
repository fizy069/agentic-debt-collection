ANTHROPIC_API_KEY=replace_with_real_key
ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI support — used only when ANTHROPIC_API_KEY is not set.
# OPENAI_API_KEY=replace_with_real_key
# OPENAI_MODEL=gpt-4o-mini
TEMPORAL_SERVER_URL=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=borrower-pipeline-task-queue

# Agent 2 (Resolution) voice mode:
# - stub: keep existing text-style Resolution behavior.
# - vapi: create a Vapi web call and wait for webhook completion.
AGENT2_VOICE_MODE=stub

# Required when AGENT2_VOICE_MODE=vapi
# VAPI_API_KEY=replace_with_real_key
# VAPI_WEBHOOK_BASE_URL=https://your-public-base-url

# Optional Vapi webhook/dashboard settings
# VAPI_WEBHOOK_CREDENTIAL_ID=cred_...
# VAPI_API_BASE_URL=https://api.vapi.ai

# Optional transient assistant defaults for Resolution voice calls
# VAPI_MODEL_PROVIDER=openai
# VAPI_MODEL_NAME=gpt-4o-mini
# VAPI_VOICE_PROVIDER=vapi
# VAPI_VOICE_ID=Elliot
# VAPI_TRANSCRIBER_PROVIDER=deepgram

# Optional webhook auth validation (configure one or both)
# VAPI_WEBHOOK_AUTH_BEARER=replace_with_expected_bearer_token
# VAPI_WEBHOOK_SECRET=replace_with_expected_x_vapi_secret

# Layer 2 compliance judge — set to "true" to enable LLM-as-a-judge auditing.
# COMPLIANCE_JUDGE_ENABLED=true
# COMPLIANCE_JUDGE_MODEL=claude-haiku-4-5

# Local vector DB for persisting judge-classified violations.
# COMPLIANCE_VECTOR_DB_PATH=data/compliance_vectors
